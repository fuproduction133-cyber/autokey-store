# AutoKey Store - Environment Configuration Template
# Copy this file to .env and fill in your values

# Flask Configuration
# IMPORTANT: Generate a strong random key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-32-char-random-key-here
FLASK_ENV=production
PORT=5000

# Admin Account (change defaults immediately!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourStrongPassword123@

# Cookie Security (enable when HTTPS is active: true/false)
SESSION_COOKIE_SECURE=true

# VietQR Configuration (REQUIRED for payment)
# Bank ID from VIETQR_BANKS dict (e.g. MBBank, Vietcombank, BIDV, etc.)
VIETQR_BANK_ID=MBBank
VIETQR_ACCOUNT_NO=YOUR_BANK_ACCOUNT_NUMBER
VIETQR_ACCOUNT_NAME=YOUR_ACCOUNT_NAME

# Database (defaults to SQLite locally; Render uses PostgreSQL via render.yaml)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
